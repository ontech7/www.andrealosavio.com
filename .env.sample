# Site URL (without https://)
NEXT_PUBLIC_SITE_URL="localhost:3000"

# Email Service (Resend)
RESEND_API_KEY="your_resend_api_key_here" # API Key: https://resend.com/api-keys
OWNER_EMAIL="your_business_email@example.com"
FROM_EMAIL="noreply@example.com"

# Security - CSRF Protection
CSRF_SECRET="your_csrf_secret_here" # openssl rand -hex 32

# Cat API (optional)
CAT_API_KEY="your_cat_api_key_here" # API Key: https://thecatapi.com/
